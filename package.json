{
  "name": "receipts",
  "version": "0.1.0",
  "description": "iMessage-native promise-keeper agent. Text it your promises; it quotes you back when you're tempted to flake.",
  "type": "module",
  "private": true,
  "engines": { "node": ">=20.6" },
  "scripts": {
    "start": "node --env-file-if-exists=.env --import tsx src/index.ts",
    "dev": "node --env-file-if-exists=.env --import tsx --watch src/index.ts",
    "chat": "node --env-file-if-exists=.env --import tsx src/chat.ts",
    "init-db": "node --env-file-if-exists=.env --import tsx src/init-db.ts"
  },
  "dependencies": {
    "@photon-ai/imessage-kit": "^2.1.2",
    "@anthropic-ai/sdk": "^0.32.1",
    "better-sqlite3": "^12.5.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.3.0"
  }
}
