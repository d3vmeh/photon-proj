ANTHROPIC_API_KEY=sk-ant-...
RECEIPTS_DB=./receipts.db

# Optional: lock the agent to one sender (phone or email).
RECEIPTS_OWNER_HANDLE=

# Optional: solo-testing mode. If set, the agent only acts on iMessages that
# start with this prefix. Lets you text YOUR OWN email from your iPhone
# without getting filtered as an "own message". Leave empty for two-device
# testing. Example: "/r"
RECEIPTS_TRIGGER_PREFIX=

# Optional: nudge poll interval in ms. Default 10000 (10s). Lower for demos.
RECEIPTS_NUDGE_MS=10000

# Optional: IANA timezone for interpreting "4pm tomorrow" in user messages.
# Defaults to the Mac's system timezone. Override if running on a server.
RECEIPTS_TIMEZONE=

# Optional: nudge escalation. If you don't respond to a level-1 nudge within
# STEP2 ms, a dryer L2 fires. STEP3 ms later, a sharp L3 that pulls the
# receipt. Defaults: 20 min, 60 min. For demos, try 30_000 and 90_000.
RECEIPTS_ESCALATE_STEP2_MS=1200000
RECEIPTS_ESCALATE_STEP3_MS=3600000

# Optional: morning digest. Sent once per local day at the configured hour
# (0-23). Summarises what you owe yourself today. Set ENABLED=false to skip.
RECEIPTS_DIGEST_ENABLED=true
RECEIPTS_DIGEST_HOUR=8

# Optional: DB path for the `npm run chat` REPL. Default :memory:.
RECEIPTS_CHAT_DB=
