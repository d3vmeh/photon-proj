ANTHROPIC_API_KEY=sk-ant-...
RECEIPTS_DB=./receipts.db

# Optional: lock the agent to one sender (phone or email).
RECEIPTS_OWNER_HANDLE=

# Optional: solo-testing mode. If set, the agent only acts on iMessages that
# start with this prefix. Lets you text YOUR OWN email from your iPhone
# without getting filtered as an "own message". Leave empty for two-device
# testing. Example: "/r"
RECEIPTS_TRIGGER_PREFIX=

# Optional: nudge poll interval in ms. Default 10000 (10s). Lower for demos.
RECEIPTS_NUDGE_MS=10000

# Optional: IANA timezone for interpreting "4pm tomorrow" in user messages.
# Defaults to the Mac's system timezone. Override if running on a server.
# Example: America/New_York, Europe/London, Asia/Tokyo
RECEIPTS_TIMEZONE=
